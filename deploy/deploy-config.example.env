# =============================================================================
# Solar Directory Deployment Configuration
# =============================================================================
# Copy this file and fill in your values before running deploy.sh:
#   cp deploy-config.example.env deploy-config.env
#
# Then run:
#   bash deploy.sh --domain findsolarinstallers.xyz --db-pass YOUR_STRONG_PASSWORD --admin-email you@email.com
# =============================================================================

# Domain name (required as CLI arg, shown here for reference)
DOMAIN=findsolarinstallers.xyz

# Database
DB_NAME=solarlisting
DB_USER=solar_user
DB_PASS=CHANGE_ME_TO_A_STRONG_PASSWORD
DB_PREFIX=fl_

# Admin
ADMIN_EMAIL=admin@findsolarinstallers.xyz

# Outscraper API (get key at https://outscraper.com)
OUTSCRAPER_API_KEY=YOUR_OUTSCRAPER_API_KEY_HERE

# Optional: Google Maps API key for geocoding fallback
GOOGLE_MAPS_API_KEY=

# Monthly Outscraper credit budget (prevents runaway costs)
MONTHLY_CREDIT_BUDGET=10000

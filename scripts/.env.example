# =============================================================================
# Solar Directory Pipeline Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Outscraper API (required for automated scraping)
# Get your key at: https://outscraper.com
OUTSCRAPER_API_KEY=your_key_here

# Monthly credit budget — pipeline stops if exceeded (prevents runaway costs)
MONTHLY_CREDIT_BUDGET=10000

# Database credentials (auto-detected from Flynax config.inc.php if not set)
# Only set these if your pipeline runs on a different server than the web app
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=solar_user
# DB_PASS=password
# DB_NAME=solarlisting
# DB_PREFIX=fl_

# Pipeline settings
WEEKLY_REGION_COUNT=5
CRAWL4AI_MAX_CONCURRENT=10
CRAWL4AI_TIMEOUT=15

# Notification email (receives pipeline status reports)
ADMIN_EMAIL=admin@findsolarinstallers.xyz

# Paths (auto-detected if not set)
# DATA_DIR=/var/www/findsolarinstallers.xyz/scripts/data
# LOG_DIR=/var/www/findsolarinstallers.xyz/scripts/logs
# FLYNAX_ROOT=/var/www/findsolarinstallers.xyz
